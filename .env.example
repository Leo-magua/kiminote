# AI Notes Configuration
# Copy this file to .env and fill in your values

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI-compatible API endpoint
# Leave empty to use default OpenAI API
# Examples:
#   - OpenAI: https://api.openai.com/v1
#   - Moonshot AI: https://api.moonshot.cn/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model to use
# Examples: gpt-3.5-turbo, gpt-4, gpt-4-turbo-preview
OPENAI_MODEL=gpt-3.5-turbo

# Application Settings
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database URL (optional, default uses local SQLite)
# DATABASE_URL=sqlite:///data/notes.db
